# SSH Configuration (for train.sh, download.sh, upload.sh)
export SSH_KEY_PATH=

# Lambda Labs Configuration (for lambda_launch.sh, lambda_terminate.sh)
export LAMBDA_API_KEY=
export LAMBDA_SSH_KEY_NAME=

# HuggingFace Token (required for gated models like Llama)
# Get yours at: https://huggingface.co/settings/tokens
export HF_TOKEN=

# Kaggle API (for dataset downloads like APTOS-2019)
# Get yours at: https://www.kaggle.com/settings → Create New API Token
export KAGGLE_USERNAME=
export KAGGLE_KEY=
